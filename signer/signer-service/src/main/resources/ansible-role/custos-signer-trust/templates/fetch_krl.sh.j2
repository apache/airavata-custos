SIGNER_URL="{{ signer_service_url }}"
TENANT_ID="{{ tenant_id }}"
CLIENT_ID="{{ client_id }}"
KRL_FILE="/etc/ssh/revoked.krl"
TEMP_KRL="/tmp/revoked.krl.tmp"
LOG_FILE="/var/log/custos-krl-fetch.log"

# Log function
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
}

log "Starting KRL fetch for tenant: $TENANT_ID, client: $CLIENT_ID"

# Fetch KRL from signer service
if ! curl -sf "${SIGNER_URL}/api/krl/${TENANT_ID}/${CLIENT_ID}" -o "${TEMP_KRL}"; then
    log "ERROR: Failed to fetch KRL from ${SIGNER_URL}/api/krl/${TENANT_ID}/${CLIENT_ID}"
    rm -f "${TEMP_KRL}"
    exit 1
fi

# Validate KRL (basic check - ensure it's not empty and has valid format)
if [ ! -s "${TEMP_KRL}" ]; then
    log "ERROR: Downloaded KRL is empty"
    rm -f "${TEMP_KRL}"
    exit 1
fi

# Check if KRL has valid SSH KRL header (simplified check)
if ! head -c 4 "${TEMP_KRL}" | grep -q "SSH"; then
    log "WARNING: Downloaded file may not be a valid SSH KRL"
fi

# Atomic replacement
if mv "${TEMP_KRL}" "${KRL_FILE}"; then
    chmod 644 "${KRL_FILE}"
    log "SUCCESS: KRL updated successfully"
    
    # Reload SSH daemon to pick up new KRL
    if systemctl reload sshd; then
        log "SUCCESS: SSH daemon reloaded"
    else
        log "WARNING: SSH daemon reload failed"
    fi
else
    log "ERROR: Failed to replace KRL file"
    rm -f "${TEMP_KRL}"
    exit 1
fi

log "KRL fetch completed successfully"
