# Copy to .env.local and fill in. Defaults assume the local Keycloak stack
# from dev-ops/compose is up; the portal will not start without it.

# Server-side
NODE_ENV=development
NEXTAUTH_SECRET=CHANGE-ME              # generate with `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000

# Custos backend
CUSTOS_CORE_API_BASE_URL=http://localhost:8080

# OIDC (required).
# Local Keycloak via dev-ops/compose; users seeded in custos-realm.json.
OIDC_ISSUER_URL=http://localhost:8081/realms/custos
OIDC_CLIENT_ID=portal
OIDC_CLIENT_SECRET=portal-dev-secret

# Client-side. MSW is for Vitest/Playwright fixture-driven tests only.
NEXT_PUBLIC_PORTAL_USE_MSW=false
NEXT_PUBLIC_PORTAL_BUILD_SHA=dev
