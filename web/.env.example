# Copy to .env.local and fill in for OIDC mode. Dev defaults boot fine without
# this file present (MSW + dev credentials).

# Server-side
# NODE_ENV=development
# PORTAL_AUTH_MODE=dev               # dev | oidc
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# Custos backend
# CUSTOS_CORE_API_BASE_URL=http://localhost:8080
# CUSTOS_ADMIN_CLIENT_ID=
# CUSTOS_ADMIN_CLIENT_SECRET=

# OIDC (required when PORTAL_AUTH_MODE=oidc)
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# Client-side
# NEXT_PUBLIC_PORTAL_USE_MSW=true
# NEXT_PUBLIC_PORTAL_BUILD_SHA=dev
