# Copy to .env.local and fill in. All OIDC values are required at boot;
# parseServer() in src/lib/env.ts throws if anything is missing.

# Server-side
# NODE_ENV=development
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# Custos backend
# CUSTOS_CORE_API_BASE_URL=http://localhost:8080
# CUSTOS_ADMIN_CLIENT_ID=
# CUSTOS_ADMIN_CLIENT_SECRET=

# OIDC (required)
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email org.cilogon.userinfo

# Client-side
# NEXT_PUBLIC_PORTAL_USE_MSW=false
# NEXT_PUBLIC_PORTAL_BUILD_SHA=dev
